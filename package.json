{
	"name": "callout-studio",
	"version": "1.0.0",
	"description": "Ultimate callout manager for Obsidian with custom types, Material Icons, native context menu actions, and full dark/light mode color control.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"prepare": "husky"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"husky": "^9.1.7",
		"jiti": "2.6.1",
		"nano-staged": "^1.0.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@codemirror/view": "6.38.6",
		"monkey-around": "^3.0.0",
		"obsidian": "1.10.3"
	},
	"nano-staged": {
		"*.{ts,mts}": "eslint"
	}
}
