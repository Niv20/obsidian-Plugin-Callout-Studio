{
	"name": "callout-studio",
	"version": "2.1.4",
	"description": "Ultimate callout manager for Obsidian with custom types, Material Icons, native context menu actions, and full dark/light mode color control.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"welcome": "open 'obsidian://callout-studio-welcome'",
		"prepare": "husky"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/language": "^6.12.4",
		"@codemirror/state": "^6.5.0",
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "14.0.0",
		"husky": "^9.1.7",
		"jiti": "2.6.1",
		"nano-staged": "^1.0.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@codemirror/view": "6.38.6",
		"monkey-around": "^3.0.0",
		"number-flow": "^0.6.0",
		"obsidian": "1.10.3"
	},
	"nano-staged": {
		"*.{ts,mts}": "eslint"
	},
	"overrides": {
		"eslint-plugin-n": "17.24.0"
	}
}
